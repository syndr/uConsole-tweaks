#!/usr/bin/env python3
"""While KEY_F24 is held on the keyd virtual keyboard (vid:pid 0fac:0ade),
translate ZMK trackball motion into scroll wheel events instead of cursor
movement. The pointer device is grabbed exclusively for the duration of the
hold, so the compositor sees scroll events only — no cursor drift.

KEY_F24 is what keyd emits when gamepad Select (KEY_FRONT) is held >200ms;
see the keyd-uconsole tweak. Tapping Select still emits KEY_FRONT for apps
and games that expect it. The indirection via F24 is what keeps Select-press
from leaking into the focused app as a real keystroke (which terminals etc.
interpret as 'exit scrollback / jump to bottom').

Resilience: USB re-enumeration of the ZMK device invalidates any open pointer
fd. We recover by treating ENODEV / OSError from either grab() or read() as
a signal to close and re-discover both devices via VID/PID scan."""

import select
import sys
import time

from evdev import InputDevice, UInput, ecodes, list_devices

KEYD_VID = 0x0FAC
KEYD_PID = 0x0ADE
ZMK_VID = 0x1D50
ZMK_PID = 0x615E
HOLD_KEY = ecodes.KEY_F24  # 194 — emitted by keyd when gamepad Select is held >200ms (see keyd-uconsole)

PIXELS_PER_TICK_V = 64
PIXELS_PER_TICK_H = 64
HI_RES_PER_NOTCH = 120  # Linux kernel convention: 120 hi-res units = 1 legacy notch

# 1 = pointer-direction matches scroll-direction (push pointer down → scroll down)
# -1 = inverted
DIR_V = 1
DIR_H = 1


def _scan(match):
    for path in list_devices():
        try:
            d = InputDevice(path)
        except Exception:
            continue
        try:
            if match(d):
                return d
        except Exception:
            pass
        d.close()
    return None


def find_keyd_kbd():
    return _scan(lambda d: d.info.vendor == KEYD_VID and d.info.product == KEYD_PID)


def find_zmk_ptr():
    # ZMK composite device exposes both a keyboard and a mouse under the same
    # VID/PID. Pick the interface that advertises relative-motion events.
    return _scan(
        lambda d: d.info.vendor == ZMK_VID
        and d.info.product == ZMK_PID
        and ecodes.EV_REL in d.capabilities()
    )


def open_devices():
    while True:
        kbd = find_keyd_kbd()
        ptr = find_zmk_ptr() if kbd is not None else None
        if kbd is not None and ptr is not None:
            return kbd, ptr
        if kbd is not None:
            kbd.close()
        if ptr is not None:
            ptr.close()
        print("waiting for keyd virtual keyboard + ZMK pointer...",
              file=sys.stderr, flush=True)
        time.sleep(2)


def main():
    kbd, ptr = open_devices()
    ui = UInput(
        {ecodes.EV_REL: [
            ecodes.REL_WHEEL,        ecodes.REL_HWHEEL,
            ecodes.REL_WHEEL_HI_RES, ecodes.REL_HWHEEL_HI_RES,
        ]},
        name="zmk-cursor-scroll",
    )
    print(f"listening: kbd={kbd.path} ({kbd.name}) ptr={ptr.path}", flush=True)

    held = False
    accum_hi_x = accum_hi_y = 0        # pointer-pixel × HI_RES_PER_NOTCH (drives REL_*_HI_RES)
    accum_notch_x = accum_notch_y = 0  # pointer-pixel (drives legacy REL_HWHEEL/REL_WHEEL)

    while True:
        watch = [kbd] + ([ptr] if held else [])
        try:
            ready, _, _ = select.select(watch, [], [])
        except InterruptedError:
            continue

        reopen = False
        for dev in ready:
            try:
                events = list(dev.read())
            except BlockingIOError:
                continue
            except OSError as e:
                print(f"read error on {dev.path}: {e}", file=sys.stderr, flush=True)
                reopen = True
                break

            if dev is kbd:
                for ev in events:
                    if ev.type == ecodes.EV_KEY and ev.code == HOLD_KEY:
                        if ev.value == 1 and not held:
                            try:
                                ptr.grab()
                                held = True
                                accum_hi_x = accum_hi_y = 0
                                accum_notch_x = accum_notch_y = 0
                            except OSError as e:
                                print(f"pointer grab failed ({e}); reopening devices",
                                      file=sys.stderr, flush=True)
                                reopen = True
                                break
                        elif ev.value == 0 and held:
                            try:
                                ptr.ungrab()
                            except OSError:
                                pass
                            held = False
                if reopen:
                    break
            elif dev is ptr and held:
                emit = False
                for ev in events:
                    if ev.type != ecodes.EV_REL:
                        continue
                    if ev.code == ecodes.REL_X:
                        accum_hi_x    += ev.value * HI_RES_PER_NOTCH
                        accum_notch_x += ev.value
                        hi    = int(accum_hi_x    / PIXELS_PER_TICK_H)  # truncates toward zero
                        notch = int(accum_notch_x / PIXELS_PER_TICK_H)
                        if hi:
                            ui.write(ecodes.EV_REL, ecodes.REL_HWHEEL_HI_RES, hi * DIR_H)
                            accum_hi_x -= hi * PIXELS_PER_TICK_H
                            emit = True
                        if notch:
                            ui.write(ecodes.EV_REL, ecodes.REL_HWHEEL, notch * DIR_H)
                            accum_notch_x -= notch * PIXELS_PER_TICK_H
                            emit = True
                    elif ev.code == ecodes.REL_Y:
                        accum_hi_y    += ev.value * HI_RES_PER_NOTCH
                        accum_notch_y += ev.value
                        hi    = int(accum_hi_y    / PIXELS_PER_TICK_V)
                        notch = int(accum_notch_y / PIXELS_PER_TICK_V)
                        if hi:
                            ui.write(ecodes.EV_REL, ecodes.REL_WHEEL_HI_RES, hi * DIR_V)
                            accum_hi_y -= hi * PIXELS_PER_TICK_V
                            emit = True
                        if notch:
                            ui.write(ecodes.EV_REL, ecodes.REL_WHEEL, notch * DIR_V)
                            accum_notch_y -= notch * PIXELS_PER_TICK_V
                            emit = True
                if emit:
                    ui.syn()

        if reopen:
            if held:
                try:
                    ptr.ungrab()
                except Exception:
                    pass
                held = False
            try:
                kbd.close()
            except Exception:
                pass
            try:
                ptr.close()
            except Exception:
                pass
            kbd, ptr = open_devices()
            accum_hi_x = accum_hi_y = 0
            accum_notch_x = accum_notch_y = 0
            print(f"reopened: kbd={kbd.path} ptr={ptr.path}", flush=True)


if __name__ == "__main__":
    main()
